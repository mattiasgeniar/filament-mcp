includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon

parameters:
    level: 8
    paths:
        - src
        - config
        - database
    tmpDir: build/phpstan
    # This package ships its own config file; env() is correct here even though
    # larastan measures "config directory" against the host app.
    noEnvCallsOutsideOfConfig: false
